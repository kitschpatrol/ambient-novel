{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ambient-novel",
	"compatibility_date": "2026-02-02",
	"dev": {
		"local_protocol": "https",
		"port": 8787
	},
	"assets": {
		"directory": "./build",
		"html_handling": "drop-trailing-slash",
		"not_found_handling": "404-page"
	},
	"workers_dev": false,
	"route": "thevalentinemob.com/*"
}
