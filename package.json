{
	"name": "ambient-novel",
	"version": "2.1.0",
	"private": true,
	"description": "An interface for nonlinear, interwoven, and interactive exploration of a novel.",
	"keywords": [
		"ambient",
		"book",
		"fiction",
		"interactive",
		"novel",
		"svelte",
		"whisper"
	],
	"homepage": "https://thevalentinemob.com",
	"bugs": "https://github.com/kitschpatrol/ambient-novel/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/ambient-novel.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"scripts": {
		"prebuild": "svelte-kit sync && pnpm run generate-package-info && pnpm run generate-licenses && pnpm run copy-source-data && ksc-prettier fix",
		"build": "pnpm run prebuild && vite build &&  tsx ./scripts/generate-version-json.ts > ./build/version.json",
		"build-report": "dust -t -b ./build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"clean": "rm -rf ./build ./node_modules pnpm-lock.yaml",
		"copy-source-data": "cp ./data/book.json ./src/lib/data/book-source.json",
		"dev": "vite dev --host",
		"fix": "ksc fix",
		"generate-data": "tsx ./scripts/generate-data.ts",
		"generate-licenses": "pnpm licenses list --json > ./src/lib/data/licenses.json",
		"generate-package-info": "jq '{version, name, description}' package.json > ./src/lib/data/pkg-info.json",
		"lint": "ksc lint && pnpm run check",
		"preview": "vite preview --host",
		"preview-server": "poptab ; open https://localhost:8787 ; wrangler dev --show-interactive-dev-session false --https-cert-path ~/.vite-plugin-mkcert/cert.pem --https-key-path ~/.vite-plugin-mkcert/dev.pem",
		"release": "bumpp --preid preview --commit 'Release: %s' --push false && pnpm run build && wrangler deploy",
		"scrape-pdf": "tsx ./scripts/scrape-pdf.ts"
	},
	"devDependencies": {
		"@cyber2024/pdf-parse-fixed": "^1.2.5",
		"@fortawesome/free-solid-svg-icons": "^6.7.2",
		"@kitschpatrol/shared-config": "^6.0.3",
		"@playwright/test": "^1.58.2",
		"@prettier/sync": "^0.6.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.54.0",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@tailwindcss/postcss": "^4.2.1",
		"@tsparticles/engine": "3.8.1",
		"@tsparticles/slim": "3.8.1",
		"@tsparticles/svelte": "3.1.1",
		"@types/glob": "^8.1.0",
		"@types/howler": "^2.2.12",
		"@types/html-minifier": "^4.0.6",
		"@types/lodash": "^4.17.24",
		"@types/node": "~22.0.3",
		"@types/pdf-parse": "^1.1.5",
		"@types/sanitize-html": "^2.16.1",
		"@types/scrollbooster": "^3.0.3",
		"@types/seedrandom": "^3.0.8",
		"@types/semver": "^7.7.1",
		"@types/tinycolor2": "^1.4.6",
		"@types/ua-parser-js": "^0.7.39",
		"bumpp": "^10.4.1",
		"dotenv": "^17.3.1",
		"execa": "^9.6.1",
		"glob": "^13.0.6",
		"html-minifier": "^4.0.0",
		"leven": "^4.1.0",
		"lodash": "^4.17.23",
		"mrmime": "^2.0.1",
		"node-addon-api": "^8.6.0",
		"node-gyp": "^12.2.0",
		"node-html-parser": "^7.1.0",
		"node-id3": "^0.2.9",
		"node-jq": "^6.3.1",
		"poptab": "^1.0.4",
		"postcss": "^8.5.8",
		"read-package-up": "^12.0.0",
		"sanitize-html": "^2.17.1",
		"scrollbooster": "^3.0.2",
		"seedrandom": "^3.0.5",
		"semver": "^7.7.4",
		"string-strip-html": "^13.5.3",
		"svelte": "^4.2.20",
		"svelte-check": "^4.4.5",
		"svelte-fa": "^4.0.4",
		"tailwindcss": "^4.2.1",
		"tinycolor2": "^1.6.0",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"ua-parser-js": "^1.0.41",
		"vite": "^5.4.21",
		"vite-plugin-mkcert": "^1.17.10",
		"workbox-build": "^7.4.0",
		"workbox-range-requests": "^7.4.0",
		"workbox-routing": "^7.4.0",
		"wrangler": "^4.72.0",
		"zod": "^3.25.76"
	},
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=22.0.0"
	}
}
